# ============================================================
# SJK SmartView — Environment Variables (ШАБЛОН)
# ============================================================
# Скопируйте этот файл в .env и заполните реальными значениями
# cp .env.example .env
# НИКОГДА не коммитьте .env в git!

# --- FastAPI ---
PORT=8000
HOST=0.0.0.0
# Список разрешённых доменов через запятую (для CORS)
# Пример: https://sjk-smartview.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- База данных ---
# PostgreSQL (продакшн / docker-compose)
DATABASE_URL=postgresql://sjk_user:sjk_pass@db:5432/sjk_db
# Для локальной разработки без Docker оставьте пустым → SQLite fallback

# --- Firebase Admin SDK ---
# Скопируйте ВЕСЬ JSON из нового Service Account ключа в одну строку
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=sjk-smartview.firebasestorage.app

# --- Modal.com (GPU AI воркер) ---
# Получить на: https://modal.com/settings/tokens
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
